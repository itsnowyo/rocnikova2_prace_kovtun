<Window x:Class="ZaverecnyProjekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZaverecnyProjekt"
        mc:Ignorable="d"
        Title="Ztracená ročníková práce"
        Height="720"
        Width="1280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid x:Name="StartScreen" Background="#FF111111">
            <StackPanel 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center">
                <TextBlock Text="ZTRACENÁ ROČNÍKOVÁ PRÁCE" 
                           Foreground="White" 
                           FontSize="36" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30" 
                           FontFamily="Segoe UI"/>
                <Button Content="▶ Začít hru" 
                        Width="220" 
                        Height="60" 
                        FontSize="22" 
                        FontWeight="Bold" 
                        Click="StartButton_Click" 
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="RoomScreen" Visibility="Hidden">
            <Image Source="/images/pokoj.png" Stretch="Fill"/>

            <Border 
                Background="#CC000000" 
                Height="110" 
                VerticalAlignment="Top" 
                BorderBrush="#33FFFFFF" 
                BorderThickness="0,0,0,1">
                <TextBlock x:Name="StoryText" 
                           Foreground="White" 
                           FontSize="20" Margin="20" 
                           TextWrapping="Wrap" 
                           FontFamily="Segoe UI"/>
            </Border>

            <Button x:Name="PcButton" 
                    Opacity="0" 
                    Width="220" 
                    Height="180" 
                    Margin="180,130,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="PcButton_Click" 
                    Cursor="Hand"/>
            <Button x:Name="BagButton" 
                    Opacity="0" 
                    Width="120" 
                    Height="140" 
                    Margin="500,420,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="BagButton_Click" 
                    Cursor="Hand"/>
            <Button x:Name="PizzaButton" 
                    Width="100" 
                    Height="100" 
                    Opacity="0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Margin="150,550,0,0" 
                    Click="PizzaButton_Click" 
                    Cursor="Hand"/>

            <Border Background="#DD111111" 
                    BorderBrush="#33FFFFFF" 
                    BorderThickness="1" 
                    Width="260" 
                    Height="140" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom" 
                    Margin="15">
                <StackPanel Margin="10">
                    <TextBlock 
                        Text="INVENTÁŘ" 
                        Foreground="#FFFFAA00" 
                        FontSize="16" 
                        FontWeight="Bold" 
                        Margin="0,0,0,5" 
                        FontFamily="Segoe UI"/>
                    <TextBlock x:Name="InventoryText" 
                               Foreground="White" 
                               FontSize="15" 
                               TextWrapping="Wrap" 
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <Button x:Name="NextButton" 
                    Content="Vyrazit do školy ➔" 
                    Width="200" 
                    Height="50" 
                    FontSize="16" 
                    FontWeight="Bold" 
                    Visibility="Hidden" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,0,35" 
                    Click="NextButton_Click"/>
        </Grid>

        <Grid x:Name="SchoolScreen" Visibility="Hidden">
            <Image Source="/images/pocitacovka.png" Stretch="Fill"/>

            <Border 
                Background="#CC000000" 
                Height="110" 
                VerticalAlignment="Top" 
                BorderBrush="#33FFFFFF" 
                BorderThickness="0,0,0,1">
                <TextBlock x:Name="SchoolStoryText" 
                           Foreground="White" 
                           FontSize="20" 
                           Margin="20" 
                           TextWrapping="Wrap" 
                           FontFamily="Segoe UI"/>
            </Border>

            <Button x:Name="MonitorButton" 
                    Opacity="0" 
                    Width="300" 
                    Height="240" 
                    Margin="560,430,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="MonitorButton_Click" 
                    Cursor="Hand"/>
            <Button x:Name="NoteButton" 
                    Opacity="0" 
                    Width="60" 
                    Height="60" 
                    Margin="920,500,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="NoteButton_Click" 
                    Cursor="Hand"/>
            <Button x:Name="WhiteboardButton" 
                    Opacity="0" 
                    Width="240" 
                    Height="230" 
                    Margin="20,240,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="WhiteboardButton_Click" 
                    Cursor="Hand"/>

            <Border Background="#DD111111" 
                    BorderBrush="#33FFFFFF" 
                    BorderThickness="1" 
                    Width="260" 
                    Height="140" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom" 
                    Margin="15">
                <StackPanel Margin="10">
                    <TextBlock 
                        Text="INVENTÁŘ" 
                        Foreground="#FFFFAA00" 
                        FontSize="16" 
                        FontWeight="Bold" 
                        Margin="0,0,0,5" 
                        FontFamily="Segoe UI"/>
                    <TextBlock x:Name="SchoolInventoryText" 
                               Foreground="White" 
                               FontSize="15" 
                               TextWrapping="Wrap" 
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <Button x:Name="EndGameButton" 
                    Content="Vstoupit do serverovny ➔" 
                    Width="220" 
                    Height="50" 
                    FontSize="16" 
                    FontWeight="Bold" 
                    Visibility="Hidden" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,0,35" 
                    Click="EndGameButton_Click"/>
        </Grid>

        <Grid x:Name="ServerRoomScreen" Visibility="Hidden">
            <Image Source="/images/serverovna.png" Stretch="Fill"/>

            <Border 
                Background="#CC000000" 
                Height="110" 
                VerticalAlignment="Top" 
                BorderBrush="#33FFFFFF" 
                BorderThickness="0,0,0,1">
                <TextBlock x:Name="ServerStoryText" 
                           Foreground="White" 
                           FontSize="20" 
                           Margin="20" 
                           TextWrapping="Wrap" 
                           FontFamily="Segoe UI"/>
            </Border>

            <Button x:Name="UsbButton" 
                    Opacity="0" 
                    Width="80" 
                    Height="80" 
                    Margin="550,400,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="UsbButton_Click" 
                    Cursor="Hand"/>
            <Button x:Name="AdminPcButton" 
                    Opacity="0"
                    Width="300" 
                    Height="250" 
                    Margin="250,300,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="AdminPcButton_Click" 
                    Cursor="Hand"/>
            <Button x:Name="FolderButton" 
                    Opacity="0" 
                    Width="120" 
                    Height="180" 
                    Margin="1100,250,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="FolderButton_Click" 
                    Cursor="Hand"/>

            <Border 
                Background="#DD111111" 
                BorderBrush="#33FFFFFF" 
                BorderThickness="1" 
                Width="260" 
                Height="140" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Bottom" 
                Margin="15">
                <StackPanel Margin="10">
                    <TextBlock 
                        Text="INVENTÁŘ" 
                        Foreground="#FFFFAA00" 
                        FontSize="16" 
                        FontWeight="Bold" 
                        Margin="0,0,0,5" 
                        FontFamily="Segoe UI"/>
                    <TextBlock x:Name="ServerInventoryText" 
                               Foreground="White" 
                               FontSize="15" 
                               TextWrapping="Wrap" 
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <Button x:Name="ToFinalButton" 
                    Content="Otevřít hlavní centrálu ➔" 
                    Width="220" 
                    Height="50" 
                    FontSize="16" 
                    FontWeight="Bold" 
                    Visibility="Hidden" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,0,35" 
                    Click="ToFinalButton_Click"/>
        </Grid>

        <Grid x:Name="FinalScreen" Visibility="Hidden">
            <Image Source="/images/4scena.png" Stretch="Fill"/>

            <Border 
                Background="#CC000000" 
                Height="140" 
                VerticalAlignment="Top" 
                BorderBrush="#33FFFFFF" 
                BorderThickness="0,0,0,1">
                <TextBlock x:Name="FinalStoryText" 
                           Foreground="White" 
                           FontSize="20" 
                           Margin="20" 
                           TextWrapping="Wrap" 
                           FontFamily="Segoe UI"/>
            </Border>

            <Button x:Name="MainTerminalButton" 
                    Opacity="0" 
                    Width="420" 
                    Height="200" 
                    Margin="430,280,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="MainTerminalButton_Click" 
                    Cursor="Hand"/>
            <Button x:Name="BoardButton" 
                    Opacity="0" 
                    Width="230" 
                    Height="170" 
                    Margin="840,210,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="BoardButton_Click" 
                    Cursor="Hand"/>
            <Button x:Name="DoorButton" 
                    Opacity="0" 
                    Width="140" 
                    Height="360" 
                    Margin="1120,220,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="DoorButton_Click" Cursor="Hand"/>
            <Button x:Name="CoffeeButton" 
                    Opacity="0" 
                    Width="110" 
                    Height="110" 
                    Margin="100,550,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Click="CoffeeButton_Click" 
                    Cursor="Hand"/>

            <Border 
                Background="#DD111111" 
                BorderBrush="#33FFFFFF" 
                BorderThickness="1" 
                Width="260" 
                Height="140" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Bottom" 
                Margin="15">
                <StackPanel Margin="10">
                    <TextBlock Text="INVENTÁŘ" 
                               Foreground="#FFFFAA00" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5" 
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="FinalInventoryText" 
                               Foreground="White" 
                               FontSize="15" 
                               TextWrapping="Wrap" 
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <Border x:Name="PinPanel" 
                    Visibility="Collapsed" 
                    Background="#EF151515" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="4" 
                    Width="320" 
                    Height="200" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <StackPanel Margin="20" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center">
                    <TextBlock Text="ZADEJTE PŘÍSTUPOVÝ PIN:" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,15" 
                               FontFamily="Segoe UI"/>
                    <TextBox x:Name="PinTextBox" 
                             Width="160" 
                             Height="35" 
                             Background="#FF222222" 
                             Foreground="White" 
                             BorderBrush="Gray" 
                             FontSize="20" 
                             HorizontalContentAlignment="Center" 
                             VerticalContentAlignment="Center" 
                             MaxLength="4" 
                             FontFamily="Consolas"/>
                    <StackPanel Orientation="Horizontal" 
                                Margin="0,20,0,0" 
                                HorizontalAlignment="Center">
                        <Button Content="POTVRDIT" 
                                Width="90" 
                                Height="30" 
                                Margin="5" 
                                FontWeight="Bold" 
                                Click="SubmitPin_Click"/>
                        <Button Content="ZRUŠIT" 
                                Width="90" 
                                Height="30" 
                                Margin="5" 
                                Click="CancelPin_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button x:Name="FinishGameButton" 
                    Content="Zastavit SCHOOL_OPTIMIZER" 
                    Width="280" 
                    Height="55" 
                    Visibility="Hidden" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,0,35" 
                    FontSize="16" 
                    FontWeight="Bold" 
                    Background="DarkRed" 
                    Foreground="White" 
                    Click="FinishGameButton_Click"/>
        </Grid>
    </Grid>
</Window>
